with nbu as (
SELECT
    sales_channel_name,
    stock_area,
    spu,
    concat_ws('&', prod_bu) AS prod_bu, -- 用分隔符将数组元素拼接成字符串
    concat_ws('&', prod_bu_code) AS prod_bu_code,
    concat_ws('&', op_bu) AS op_bu,
    concat_ws('&', op_bu_code) AS op_bu_code,
    concat_ws('&', op_bu_sc_code) AS op_bu_sc_code,
    concat_ws('&', op_bu_sc) AS op_bu_sc,
    concat_ws('&', pm_name) AS pm_name,
    concat_ws('&', pm_mail) AS pm_mail,
    concat_ws('&', merch_ops_name) AS merch_ops_name,
    concat_ws('&', merch_ops_mail) AS merch_ops_mail,
    concat_ws('&', delivery_manager) AS delivery_manager,
    concat_ws('&', dm_mail) AS dm_mail,
    concat_ws('&', post_port_fulfillment_specialist) AS pp_fulfill_sp,
    concat_ws('&', pp_fulfill_sp_mail) AS pp_fulfill_sp_mail,
    concat_ws('&', development_procurement_manager) AS dev_proc_mgr,
    concat_ws('&', dev_proc_mgr_mail) AS dev_proc_mgr_mail
FROM
    (SELECT
        sales_channel_name,
        stock_area,
        spu,
        collect_set(prod_bu) AS prod_bu, -- 去重聚合成一个数组
        collect_set(prod_bu_code) AS prod_bu_code,
        collect_set(op_bu) AS op_bu,
        collect_set(op_bu_code) AS op_bu_code,
        collect_set(op_bu_sc_code) as op_bu_sc_code,
        collect_set(op_bu_sc)as op_bu_sc,
        collect_set(pm_name) as pm_name,
        collect_set(pm_mail) as pm_mail,
        collect_set(merch_ops_name) as merch_ops_name,
        collect_set(merch_ops_mail) as merch_ops_mail,
        collect_set(delivery_manager) as delivery_manager,
        collect_set(dm_mail) as dm_mail,
        collect_set(post_port_fulfillment_specialist) as post_port_fulfillment_specialist,
        collect_set(pp_fulfill_sp_mail) as pp_fulfill_sp_mail,
        collect_set(development_procurement_manager) as development_procurement_manager,
        collect_set(dev_proc_mgr_mail) as dev_proc_mgr_mail
    FROM dim_spu_bu_attribution
    GROUP BY 1,2,3) a
)
-- 1、先按照sku、sales_channel_code、stock_area取创建年月最新的记录
-- 2、相同的sku、sales_channel_code、stock_area、year_id、month_id、sites_group中，仅获取created_time为最新且enabled=1（有效）的
 ,sf as (
    SELECT 
    SKU,
    SALES_CHANNEL_CODE,
    SALES_CHANNEL_NAME,
    STOCK_AREA,
    create_ym,
    sum(case when d.first_date_of_month ='${指定年月首日}' then FORECAST_SALES_CNT else 0 end ) AS f0_cnt,
    sum(case when d.first_date_of_month = date_add('${指定年月首日}', interval 1 month) then FORECAST_SALES_CNT else 0 end ) AS f1_cnt,
    sum(case when d.first_date_of_month = date_add('${指定年月首日}', interval 2 month) then FORECAST_SALES_CNT else 0 end ) AS f2_cnt,
    sum(case when d.first_date_of_month = date_add('${指定年月首日}', interval 3 month) then FORECAST_SALES_CNT else 0 end ) AS f3_cnt,
    sum(case when d.first_date_of_month = date_add('${指定年月首日}', interval 4 month) then FORECAST_SALES_CNT else 0 end ) AS f4_cnt,
    sum(case when d.first_date_of_month = date_add('${指定年月首日}', interval 5 month) then FORECAST_SALES_CNT else 0 end ) AS f5_cnt
    FROM (
        SELECT
        YEAR_ID,
        MONTH_ID,
        SKU,
        SALES_CHANNEL_CODE,
        STOCK_AREA,
        SALES_CHANNEL_NAME,
        FORECAST_SALES_CNT,
        ENABLED,
        DATE_FORMAT(CREATEDATE, '%Y-%m') AS create_ym,
        MAX(DATE_FORMAT(CREATEDATE, '%Y-%m')) OVER ( PARTITION BY sku, stock_area, sales_channel_code ) AS max_create_ym,
        ROW_NUMBER() OVER (PARTITION BY YEAR_ID,MONTH_ID,SKU,SALES_CHANNEL_CODE,STOCK_AREA,SITES_GROUP,
        DATE_FORMAT(CREATEDATE, '%Y-%m') ORDER BY CREATEDATE DESC) AS rank
        FROM
        odbc_bpm.bo_eu_sales_forecast
        WHERE CREATEDATE > '2026-05-01 00:00:00' 
        ) AS t1
    left join (select distinct first_date_of_month,year_id,month_id from dim_date) d on t1.year_id = d.year_id and t1.month_id = d.month_id
    WHERE rank = 1
    and ENABLED = 1
    and create_ym = max_create_ym
                group by 1,2,3,4,5
 )
select 
st.cur_date,
nbu.prod_bu,
nbu.op_bu,
st.sales_channel_name,
st.stock_area,
st.sku,
st.spu,
bi1.category_level1,
bi1.category_level2,
bi1.category_level3,
st.sku_type,
gnpt.global_sku_first_order_date, -- SKU全球首单日期
gnpt.global_spu_first_order_date, -- SPU全球首单日期
(case when year(gnpt.global_sku_first_order_date) = year(gnpt.global_spu_first_order_date)  or gnpt.global_spu_first_order_date is null then '年度新品'
 when year(gnpt.global_sku_first_order_date) =2026 and year(gnpt.global_spu_first_order_date)< 2026 then '年度衍生品'
 else '年度旧品' end ) as np_tag,
st.purchase_total_stock * st.cost_price as purchase_stock_amt, -- 采购段库存
st.total_supplier_stock * st.cost_price as domestic_stock_amt, -- 国内段库存
st.total_overseas_stock_available_cnt * st.cost_price as overseas_stock_amt, -- 海外段库存
st.total_stock_available_cnt * st.cost_price as total_stock_amt, -- 全段库存
st.cost_price,
'${指定年月首日}' as forecast_ym,
sf.f0_cnt,
sf.f1_cnt,
sf.f2_cnt,
sf.f3_cnt,
sf.f4_cnt,
sf.f5_cnt,
sf.create_ym
FROM dws_stock_all_stockup_detail st 
left join dwd_spu_sku_basic_information bi1 on st.sku = bi1.sku
left join dim_new_product_tag_supplychain sc on st.stock_area = sc.stock_area and st.sales_channel_name = sc.sales_channel_name and st.sku = sc.sku 
left join (select distinct sku,global_sku_first_order_date,global_spu_first_order_date from dim_new_product_tag_channel) gnpt 
on st.sku = gnpt.sku 
left join nbu on ifnull(st.sales_channel_name,'') = nbu.sales_channel_name and ifnull(st.stock_area,'') = nbu.stock_area and ifnull(bi1.spu,'') = nbu.spu
left join sf on  st.sales_channel_name = sf.sales_channel_name and st.stock_area = sf.stock_area and st.sku = sf.sku 
where st.cur_date ='${备货表日期}' 
